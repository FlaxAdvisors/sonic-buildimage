
SPATH       := $($(GENL_PACKET_MODULE)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) rules/sonic-genl-packet-ko.mk rules/sonic-genl-packet-ko.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
DEP_FILES   += $(shell git ls-files $(SPATH))

$(GENL_PACKET_MODULE)_CACHE_MODE  := GIT_CONTENT_SHA
$(GENL_PACKET_MODULE)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(GENL_PACKET_MODULE)_DEP_FILES   := $(DEP_FILES)
