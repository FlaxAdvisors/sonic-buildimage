{
    "_comment": "Wedge100S L3 template — dual-ToR k8s complex. Use gen-l3-config.py to generate the full per-switch version for ZTP. REPLACE-WITH-* placeholders must be filled for deployment.",

    "DEVICE_METADATA": {
        "localhost": {
            "hostname": "REPLACE-WITH-HOSTNAME",
            "platform": "x86_64-accton_wedge100s_32x-r0",
            "hwsku": "Accton-WEDGE100S-32X",
            "mac": "REPLACE-WITH-MAC",
            "type": "LeafRouter",
            "bgp_asn": "65000"
        }
    },

    "FEATURE": {
        "bgp": {
            "state": "enabled",
            "auto_restart": "enabled",
            "has_per_asic_scope": "False",
            "has_global_scope": "True",
            "has_timer": "False"
        }
    },

    "MGMT_INTERFACE": {
        "eth0": {},
        "eth0|REPLACE-WITH-MGMT-IP/PREFIX": {
            "gwaddr": "REPLACE-WITH-MGMT-GW"
        }
    },

    "MGMT_VRF_CONFIG": {
        "vrf_global": {
            "mgmtVrfEnabled": "true"
        }
    },

    "LOOPBACK_INTERFACE": {
        "Loopback0": {},
        "Loopback0|10.1.0.1/32": {}
    },

    "BREAKOUT_CFG": {
        "_comment": "P5-10 (E16-E36) and P23-28 (E88-E108) break to 4x25G for server-facing ports",
        "Ethernet16":  { "brkout_mode": "4x25G[10G]" },
        "Ethernet20":  { "brkout_mode": "4x25G[10G]" },
        "Ethernet24":  { "brkout_mode": "4x25G[10G]" },
        "Ethernet28":  { "brkout_mode": "4x25G[10G]" },
        "Ethernet32":  { "brkout_mode": "4x25G[10G]" },
        "Ethernet36":  { "brkout_mode": "4x25G[10G]" },
        "Ethernet88":  { "brkout_mode": "4x25G[10G]" },
        "Ethernet92":  { "brkout_mode": "4x25G[10G]" },
        "Ethernet96":  { "brkout_mode": "4x25G[10G]" },
        "Ethernet100": { "brkout_mode": "4x25G[10G]" },
        "Ethernet104": { "brkout_mode": "4x25G[10G]" },
        "Ethernet108": { "brkout_mode": "4x25G[10G]" }
    },

    "INTERFACE": {
        "_comment": "Node 1 NIC0 → Wedge A (left side, sub-port E16 from P5 breakout)",
        "Ethernet16": {},
        "Ethernet16|10.0.1.0/31": {},
        "_comment2": "Node 2 NIC0 → Wedge A",
        "Ethernet17": {},
        "Ethernet17|10.0.2.0/31": {},
        "_comment3": "... E18=node3, E19=node4, E20=node5 ... E39=node24 (left side complete)",
        "_comment4": "Node 25 NIC0 → Wedge A (right side, sub-port E88 from P23 breakout)",
        "Ethernet88": {},
        "Ethernet88|10.0.25.0/31": {},
        "_comment5": "... E89=node26 ... E111=node48 (right side complete)",
        "_comment6": "Storage ports (single-attach /30, switch gets .1)",
        "Ethernet40": {},
        "Ethernet40|10.2.1.1/30": {},
        "Ethernet44": {},
        "Ethernet44|10.2.2.1/30": {},
        "Ethernet80": {},
        "Ethernet80|10.2.3.1/30": {},
        "Ethernet84": {},
        "Ethernet84|10.2.4.1/30": {},
        "_comment7": "Inter-switch link — Wedge A=10.255.0.0, Wedge B=10.255.0.1",
        "Ethernet0": {},
        "Ethernet0|10.255.0.0/31": {},
        "_comment8": "Uplink P29 (E112) — provider-assigned",
        "Ethernet112": {},
        "Ethernet112|REPLACE-WITH-UPLINK-IP/PREFIX": {}
    },

    "STATIC_ROUTE": {
        "default": {
            "0.0.0.0/0": {
                "nexthop": "REPLACE-WITH-UPSTREAM-GW",
                "ifname": "Ethernet112"
            }
        }
    },

    "BGP_GLOBALS": {
        "default": {
            "local_asn": "65000",
            "router_id": "10.1.0.1",
            "load_balance_mp_relax": "true",
            "graceful_restart_enable": "true",
            "graceful_restart_preserve_fw_state": "true"
