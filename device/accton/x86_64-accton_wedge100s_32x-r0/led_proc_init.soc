m CMIC_LEDUP1_PORT_ORDER_REMAP_0_3    REMAP_PORT_0=29   REMAP_PORT_1=28   REMAP_PORT_2=31   REMAP_PORT_3=30
m CMIC_LEDUP1_PORT_ORDER_REMAP_4_7    REMAP_PORT_4=1    REMAP_PORT_5=0    REMAP_PORT_6=3    REMAP_PORT_7=2
