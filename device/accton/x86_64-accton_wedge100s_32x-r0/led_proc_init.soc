# led_proc_init.soc — LED microcontroller init for Accton Wedge 100S-32X
#
# BCM56960 (Tomahawk) has two LED scan chains: LEDUP0 and LEDUP1.
# Each drives one color channel of the per-port bi-color LED.
# The LED bytecode (below) is identical to AS7712-32X — same Tomahawk chip,
# same 32×100G QSFP28 layout.
#
# PORT ORDER REMAP derivation:
#   LED physical port index = (first_serdes_lane - 1) / 4
#   Source: portmap_*.0=<serdes>:100 entries in th-wedge100s-32x-flex.config.bcm
#
#   Chain  FP port  SONiC iface  First lane  LED port
#   pos 0  fp1      Ethernet0    117         29
#   pos 1  fp2      Ethernet4    113         28
#   pos 2  fp3      Ethernet8    125         31
#   pos 3  fp4      Ethernet12   121         30
#   pos 4  fp5      Ethernet16   5           1
#   pos 5  fp6      Ethernet20   1           0
#   pos 6  fp7      Ethernet24   13          3
#   pos 7  fp8      Ethernet28   9           2
#   pos 8  fp9      Ethernet32   21          5
#   pos 9  fp10     Ethernet36   17          4
#   pos 10 fp11     Ethernet40   29          7
#   pos 11 fp12     Ethernet44   25          6
#   pos 12 fp13     Ethernet48   37          9
#   pos 13 fp14     Ethernet52   33          8
#   pos 14 fp15     Ethernet56   45          11
#   pos 15 fp16     Ethernet60   41          10
#   pos 16 fp17     Ethernet64   53          13
#   pos 17 fp18     Ethernet68   49          12
#   pos 18 fp19     Ethernet72   61          15
#   pos 19 fp20     Ethernet76   57          14
#   pos 20 fp21     Ethernet80   69          17
#   pos 21 fp22     Ethernet84   65          16
#   pos 22 fp23     Ethernet88   77          19
#   pos 23 fp24     Ethernet92   73          18
#   pos 24 fp25     Ethernet96   85          21
#   pos 25 fp26     Ethernet100  81          20
#   pos 26 fp27     Ethernet104  93          23
#   pos 27 fp28     Ethernet108  89          22
#   pos 28 fp29     Ethernet112  101         25
#   pos 29 fp30     Ethernet116  97          24
#   pos 30 fp31     Ethernet120  109         27
#   pos 31 fp32     Ethernet124  105         26
#
# Positions 32-63 are unused on a 32-port platform; values are don't-care.
# NOTE: PCB wiring not confirmed from schematic.  If individual port LEDs
# show wrong link status, swap pairs in the REMAP table and re-test.

m CMIC_LEDUP0_PORT_ORDER_REMAP_0_3    REMAP_PORT_0=29   REMAP_PORT_1=28   REMAP_PORT_2=31   REMAP_PORT_3=30
m CMIC_LEDUP0_PORT_ORDER_REMAP_4_7    REMAP_PORT_4=1    REMAP_PORT_5=0    REMAP_PORT_6=3    REMAP_PORT_7=2
m CMIC_LEDUP0_PORT_ORDER_REMAP_8_11   REMAP_PORT_8=5    REMAP_PORT_9=4    REMAP_PORT_10=7   REMAP_PORT_11=6
m CMIC_LEDUP0_PORT_ORDER_REMAP_12_15  REMAP_PORT_12=9   REMAP_PORT_13=8   REMAP_PORT_14=11  REMAP_PORT_15=10
m CMIC_LEDUP0_PORT_ORDER_REMAP_16_19  REMAP_PORT_16=13  REMAP_PORT_17=12  REMAP_PORT_18=15  REMAP_PORT_19=14
m CMIC_LEDUP0_PORT_ORDER_REMAP_20_23  REMAP_PORT_20=17  REMAP_PORT_21=16  REMAP_PORT_22=19  REMAP_PORT_23=18
m CMIC_LEDUP0_PORT_ORDER_REMAP_24_27  REMAP_PORT_24=21  REMAP_PORT_25=20  REMAP_PORT_26=23  REMAP_PORT_27=22
m CMIC_LEDUP0_PORT_ORDER_REMAP_28_31  REMAP_PORT_28=25  REMAP_PORT_29=24  REMAP_PORT_30=27  REMAP_PORT_31=26
