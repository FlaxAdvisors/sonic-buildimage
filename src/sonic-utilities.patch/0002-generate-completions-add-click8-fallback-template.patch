From 9a408e6180566e11bd465ee8dcbd1facc86a0651 Mon Sep 17 00:00:00 2001
From: wedge100s-port <wedge100s@local>
Date: 2026-03-17
Subject: [PATCH] generate_completions: add Click 8 fallback template for import failures

During the SONiC build, generate_completions.py runs inside the
sonic-slave-trixie container where some transitive dependencies
(e.g. sonic-platform wheel) are not installed.  When a CLI
entry-point module fails to import, the existing code prints a
message and silently skips the completion file, leaving bash
completion broken on the target for those commands.

Add _FALLBACK_TMPL: a static Click 8 bash-completion shell function
that sets the _<CMD>_COMPLETE=bash_complete environment variable and
delegates to the program at runtime (where all deps ARE present).
The generated file is functionally identical to what Click's
source() method would produce.

On import failure, instead of skipping: write the fallback template,
so every entry-point ships a working completion file regardless of
build-environment dependency availability.
---
 sonic-utilities-data/generate_completions.py | 29 +++++++++++++++++--
 1 file changed, 27 insertions(+), 2 deletions(-)

diff --git a/sonic-utilities-data/generate_completions.py b/sonic-utilities-data/generate_completions.py
index dfa2ff7..dda736d 100755
--- a/sonic-utilities-data/generate_completions.py
+++ b/sonic-utilities-data/generate_completions.py
@@ -7,6 +7,35 @@ from click.shell_completion import get_completion_class
 import os.path

+# Fallback Click 8 bash completion template used when a CLI module cannot be
+# imported at build time (e.g. transitive deps missing in the slave container).
+# The generated shell function is functionally identical to what Click's own
+# source() method would produce: it sets _<CMD>_COMPLETE=bash_complete at
+# runtime so Click performs the actual completion in the user's shell.
+_FALLBACK_TMPL = """\
+_{func}() {{
+    local IFS=$'\\n'
+    local response
+    response=$(env COMP_WORDS="${{COMP_WORDS[*]}}" COMP_CWORD=$COMP_CWORD \\
+               {envvar}=bash_complete {prog} 2>/dev/null)
+    for completion in $response; do
+        IFS=',' read type value <<< "$completion"
+        if [[ $type == 'plain' ]]; then
+            COMPREPLY+=($value)
+        elif [[ $type == 'dir' ]]; then
+            COMPREPLY=(); compopt -o dirnames
+        elif [[ $type == 'file' ]]; then
+            COMPREPLY=(); compopt -o default
+        fi
+    done
+    return 0
+}}
+_{func}_setup() {{
+    complete -o nosort -F _{func} {prog}
+}}
+_{func}_setup;
+"""
+

 def generate_completions(output_dir):
     entry_points = importlib.metadata.distribution("sonic_utilities").entry_points
@@ -32,7 +61,17 @@ def generate_completions(output_dir):
                 with open(os.path.join(output_dir, prog), "w", newline="") as f:
                     f.write(content)
         except Exception:
-            print(f"Cannot generate completion for {path}!")
+            # Import failed (transitive dependency not installed in the build
+            # environment).  Fall back to a static Click 8 template so the
+            # completion file is still shipped.  The generated function is
+            # equivalent to what Click would produce and works at runtime
+            # where all dependencies are present.
+            print(f"Cannot import {path} — using fallback template for {prog}")
+            envvar = f"_{prog.upper().replace('-', '_')}_COMPLETE"
+            func = prog.lower().replace("-", "_") + "_completion"
+            content = _FALLBACK_TMPL.format(func=func, envvar=envvar, prog=prog)
+            with open(os.path.join(output_dir, prog), "w", newline="") as f:
+                f.write(content)


 if __name__ == "__main__":
