@@ -268,7 +268,7 @@ def systemReboot():
     '''!
     Helper API to reboot the device.
     '''
-    (rc, reboot_help, errStr)  = runCommand('reboot -h | grep "\-y"', use_shell=True)
+    (rc, reboot_help, errStr)  = runCommand(r'reboot -h | grep "\-y"', use_shell=True)
     if rc == 0:
         os.system('reboot -y')
     else:
