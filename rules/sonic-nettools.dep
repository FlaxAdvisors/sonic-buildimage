
SPATH       := $($(SONIC_NETTOOLS)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) rules/sonic-nettools.mk rules/sonic-nettools.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
SMDEP_FILES := $(addprefix $(SPATH)/,$(shell cd $(SPATH) && git ls-files))

$(SONIC_NETTOOLS)_CACHE_MODE  := GIT_CONTENT_SHA
$(SONIC_NETTOOLS)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(SONIC_NETTOOLS)_DEP_FILES   := $(DEP_FILES)
$(SONIC_NETTOOLS)_SMDEP_FILES := $(SMDEP_FILES)
$(SONIC_NETTOOLS)_SMDEP_PATHS := $(SPATH)
