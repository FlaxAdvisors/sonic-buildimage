From dd943981b109601cbe71fdb9f0f40b149ed43ac9 Mon Sep 17 00:00:00 2001
From: db-at-work <22159364+db-at-work@users.noreply.github.com>
Date: Sat, 28 Mar 2026 21:52:20 -0700
Subject: [PATCH] fix: escape Doxygen backslash sequences in ZTP docstrings for
 Python 3.12+

Python 3.12 promotes SyntaxWarning to visible output for unrecognized escape
sequences in non-raw strings. ZTP docstrings used Doxygen-style \brief,
\code, \endcode markers and one grep pattern with \- that triggered this.
Fix: double the backslashes in docstrings, use raw string for grep pattern.
---
 src/usr/lib/python3/dist-packages/ztp/DecodeSysEeprom.py | 2 +-
 src/usr/lib/python3/dist-packages/ztp/Downloader.py      | 6 +++---
 src/usr/lib/python3/dist-packages/ztp/JsonReader.py      | 6 +++---
 src/usr/lib/python3/dist-packages/ztp/Logger.py          | 6 +++---
 src/usr/lib/python3/dist-packages/ztp/ZTPCfg.py          | 6 +++---
 src/usr/lib/python3/dist-packages/ztp/ZTPLib.py          | 2 +-
 src/usr/lib/python3/dist-packages/ztp/ZTPObjects.py      | 6 +++---
 src/usr/lib/python3/dist-packages/ztp/ZTPSections.py     | 4 ++--
 8 files changed, 19 insertions(+), 19 deletions(-)

diff --git a/src/usr/lib/python3/dist-packages/ztp/DecodeSysEeprom.py b/src/usr/lib/python3/dist-packages/ztp/DecodeSysEeprom.py
index d822cb4..4c2a15d 100644
--- a/src/usr/lib/python3/dist-packages/ztp/DecodeSysEeprom.py
+++ b/src/usr/lib/python3/dist-packages/ztp/DecodeSysEeprom.py
@@ -23,7 +23,7 @@ from ztp.ZTPLib import runCommand, printable
 class DecodeSysEeprom:
 
     '''!
-    \brief This class allow to log data to stdout and/or to a file.
+    \\brief This class allow to log data to stdout and/or to a file.
     '''
 
     def __init__(self):
diff --git a/src/usr/lib/python3/dist-packages/ztp/Downloader.py b/src/usr/lib/python3/dist-packages/ztp/Downloader.py
index 7f3348d..aa36094 100644
--- a/src/usr/lib/python3/dist-packages/ztp/Downloader.py
+++ b/src/usr/lib/python3/dist-packages/ztp/Downloader.py
@@ -27,11 +27,11 @@ from ztp.ZTPLib import runCommand, get_sonic_version, getCfg
 class Downloader:
 
     '''!
-    \brief This class allow to use curl to retrieve data from a server.
+    \\brief This class allow to use curl to retrieve data from a server.
 
     Examples of class usage:
 
-    \code
+    \\code
     ztpDownload = Downloader()
 
     # Success
@@ -41,7 +41,7 @@ class Downloader:
     # Failure
     rc,data = ztpDownload.getUrl('http://10.27.219.247:8081/content/test.txt', 'test.txt');
     print rc, data
-    \endcode
+    \\endcode
     '''
 
     def __init__(self, url=None, dst_file=None, incl_http_headers=None, is_secure=None, timeout=None, retry=None, curl_args=None, encrypted=None):
diff --git a/src/usr/lib/python3/dist-packages/ztp/JsonReader.py b/src/usr/lib/python3/dist-packages/ztp/JsonReader.py
index 4b6c6d1..d400038 100644
--- a/src/usr/lib/python3/dist-packages/ztp/JsonReader.py
+++ b/src/usr/lib/python3/dist-packages/ztp/JsonReader.py
@@ -23,18 +23,18 @@ from functools import partial
 class JsonReader(object):
 
     '''!
-    \brief This class allow to download a json file, and convert it into a Python dict object.
+    \\brief This class allow to download a json file, and convert it into a Python dict object.
 
     When the data change in the dict variable, it can be automatically rewritten either in the original file,
     or optionaly in a different file.
 
     Examples of class usage:
-    \code
+    \\code
     objJson, json_dict = JsonReader("example.json", "saved.json", indent=4)
     url_dict = json_dict.get('url')
     data_dict = url_dict.get('data')
     objJson.set(data_dict, 'first_name', "William", save=True)
-    \endcode
+    \\endcode
     '''
 
     def __init__(self, src_json_file=None, dst_json_file=None, create_dst_file_parent_dirs=True, indent=None):
diff --git a/src/usr/lib/python3/dist-packages/ztp/Logger.py b/src/usr/lib/python3/dist-packages/ztp/Logger.py
index a89a71f..02025bf 100644
--- a/src/usr/lib/python3/dist-packages/ztp/Logger.py
+++ b/src/usr/lib/python3/dist-packages/ztp/Logger.py
@@ -23,7 +23,7 @@ from ztp.ZTPLib import isString, getTimestamp, getCfg, runCommand
 class Logger:
 
