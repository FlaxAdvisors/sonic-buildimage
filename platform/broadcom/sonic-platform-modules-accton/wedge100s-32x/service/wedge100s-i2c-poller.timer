[Unit]
Description=Wedge100S QSFP I2C poller timer (presence + event-driven EEPROM)

[Timer]
# First run 5 s after boot — platform-init finishes ~3 s before this fires.
OnBootSec=5s
# Poll every 3 s: 4 PCA9535 SMBus reads (~5 ms each, ~20 ms/cycle).
# EEPROM reads only on insertion; steady-state I2C traffic is minimal.
OnUnitActiveSec=3s
AccuracySec=1

[Install]
WantedBy=timers.target
