        "10.0.1.1": {
            "rrclient": "0", "name": "node01", "local_addr": "10.0.1.0",
            "nhopself": "0", "holdtime": "9", "asn": "64512", "keepalive": "3",
            "peer_group_name": "NODES"
        },
        "10.0.2.1": {
            "rrclient": "0", "name": "node02", "local_addr": "10.0.2.0",
            "nhopself": "0", "holdtime": "9", "asn": "64513", "keepalive": "3",
            "peer_group_name": "NODES"
        },
        "_comment2": "... nodes 3-47 follow same pattern ...",
        "10.0.48.1": {
            "rrclient": "0", "name": "node48", "local_addr": "10.0.48.0",
            "nhopself": "0", "holdtime": "9", "asn": "64559", "keepalive": "3",
            "peer_group_name": "NODES"
        },
        "_comment3": "Inter-switch: Wedge A peers with Wedge B (10.255.0.1, AS 65001)",
        "10.255.0.1": {
            "rrclient": "0", "name": "wedge-b", "local_addr": "10.255.0.0",
            "nhopself": "0", "holdtime": "9", "asn": "65001", "keepalive": "3",
            "peer_group_name": "SWITCHES"
        },
        "_comment4": "Upstream BGP peer — activate when case A upstream available",
        "REPLACE-WITH-UPSTREAM-IP": {
            "rrclient": "0", "name": "upstream", "local_addr": "REPLACE-WITH-UPLINK-IP",
            "nhopself": "0", "holdtime": "9", "asn": "REPLACE-WITH-UPSTREAM-ASN", "keepalive": "3"
        }
    },

    "BGP_NEIGHBOR_AF": {
        "10.0.1.1|ipv4":   { "admin_status": "true", "soft_reconfiguration_in": "true" },
        "10.0.2.1|ipv4":   { "admin_status": "true", "soft_reconfiguration_in": "true" },
        "10.0.48.1|ipv4":  { "admin_status": "true", "soft_reconfiguration_in": "true" },
        "10.255.0.1|ipv4": { "admin_status": "true", "soft_reconfiguration_in": "true" }
    }
