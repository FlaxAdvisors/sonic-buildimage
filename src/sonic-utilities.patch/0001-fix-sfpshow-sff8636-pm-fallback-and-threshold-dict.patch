From 0000000000000000000000000000000000000001 Mon Sep 17 00:00:00 2001
From: wedge100s-port <wedge100s@local>
Date: 2026-03-28
Subject: [PATCH] fix: sfpshow SFF-8636/QSFP28 PM fallback and threshold dict crash

Two fixes in sfpshow's show_pm_info():

1. sfp_threshold_dict NoneType crash: state_db.get_all() returns None when
   the TRANSCEIVER_DOM_THRESHOLD key is absent.  The subsequent
   convert_vdm_fields_to_legacy_fields() call iterates over the dict and
   raises TypeError.  Fix: add `or {}` so an empty dict is used instead.

2. SFF-8636 / QSFP28 PM display: when the port is not a CMIS/ZR transceiver,
   show_pm_info() previously returned ZR_PM_NOT_APPLICABLE_STR, which is
   confusing on QSFP28 optics that have real DOM data in TRANSCEIVER_DOM_SENSOR.
   Add a fallback that renders per-lane Rx Power, Tx Bias and Tx Power from
   TRANSCEIVER_DOM_SENSOR, plus module-level temperature and voltage.  CMIS
   and ZR ports are unaffected (the existing tabulate path still runs).

   Also adds SFF8636_PM_HEADER constant for the fallback table header.
---
 scripts/sfpshow | 26 ++++++++++++++++++++++++--
 1 file changed, 24 insertions(+), 2 deletions(-)

diff --git a/scripts/sfpshow b/scripts/sfpshow
index 05754e44..4d35efd0 100755
--- a/scripts/sfpshow
+++ b/scripts/sfpshow
@@ -253,6 +253,8 @@ ZR_PM_INFO_MAP = {

 ZR_PM_NOT_APPLICABLE_STR = 'Transceiver performance monitoring not applicable'

+SFF8636_PM_HEADER = ['Lane', 'Rx Power (dBm)', 'Tx Bias (mA)', 'Tx Power (dBm)']
+
 QSFP_STATUS_NOT_APPLICABLE_STR = 'Transceiver status info not applicable'

 def display_invalid_intf_eeprom(intf_name):
@@ -609,10 +611,9 @@ class SFPShow(object):
         sfp_pm_dict = state_db.get_all(
             self.db.STATE_DB, 'TRANSCEIVER_PM|{}'.format(first_subport))
         sfp_threshold_dict = state_db.get_all(
-            state_db.STATE_DB, 'TRANSCEIVER_DOM_THRESHOLD|{}'.format(first_subport))
+            state_db.STATE_DB, 'TRANSCEIVER_DOM_THRESHOLD|{}'.format(first_subport)) or {}
         # Convert VDM THRESHOLD fields to legacy DOM THRESHOLD fields
         self.convert_vdm_fields_to_legacy_fields(state_db, first_subport, sfp_threshold_dict, CCMIS_VDM_THRESHOLD_TO_LEGACY_DOM_THRESHOLD_MAP, 'THRESHOLD')
-        table = []
         indent_num = 4
         indent = ' ' * indent_num
         if sfp_pm_dict:
@@ -650,7 +651,26 @@ class SFPShow(object):
                                ZR_PM_HEADER, disable_numparse=True).replace('\n', '\n' + indent)
             output += '\n'
         else:
-            output = ZR_PM_NOT_APPLICABLE_STR + '\n'
+            # SFF-8636 / QSFP28 intensity-modulated fallback: render TRANSCEIVER_DOM_SENSOR
+            sfp_info_dict = state_db.get_all(state_db.STATE_DB, 'TRANSCEIVER_INFO|{}'.format(interface_name)) or {}
+            is_cmis = is_transceiver_cmis(sfp_info_dict)
+            dom_sensor_dict = state_db.get_all(state_db.STATE_DB, 'TRANSCEIVER_DOM_SENSOR|{}'.format(first_subport)) or {}
+            if not is_cmis and dom_sensor_dict:
+                lane_rows = []
+                for lane in range(1, 5):
+                    rx = dom_sensor_dict.get('rx{}power'.format(lane), 'N/A')
+                    bias = dom_sensor_dict.get('tx{}bias'.format(lane), 'N/A')
+                    txpwr = dom_sensor_dict.get('tx{}power'.format(lane), 'N/A')
+                    lane_rows.append([str(lane), str(rx), str(bias), str(txpwr)])
+                output = '\n' + indent
+                output += tabulate(lane_rows, SFF8636_PM_HEADER,
+                                   disable_numparse=True).replace('\n', '\n' + indent)
+                temp = dom_sensor_dict.get('temperature', 'N/A')
+                voltage = dom_sensor_dict.get('voltage', 'N/A')
+                output += '\n{}Temperature: {} C\n{}Voltage: {} Volts\n'.format(
+                    indent, temp, indent, voltage)
+            else:
+                output = ZR_PM_NOT_APPLICABLE_STR + '\n'
         return output

     def is_valid_physical_port(self, port_name):
