[target]
# IP address or hostname of the Wedge 100S-32X running SONiC
host = 192.168.1.100
port = 22
username = admin
password = YourPasswordHere

# Optional: path to SSH private key (leave commented to use password auth)
# key_file = ~/.ssh/id_rsa

# Optional: connect timeout in seconds (default 30)
# connect_timeout = 30

[links]
# Ports on this device connected to a peer (used by stage_13, stage_16).
# Comma or space separated.  Defaults used if this section is absent.
connected_ports = Ethernet16,Ethernet32,Ethernet48,Ethernet112

# IP addresses for stage_20 traffic tests.
# peer_ip: peer side of PortChannel1 (10.0.1.1/31 on SONiC side, 10.0.1.0/31 on peer side).
# standalone_peer_ip: peer side of Ethernet48 standalone link (10.0.0.1/31 on SONiC side).
peer_ip = 10.0.1.0
standalone_peer_ip = 10.0.0.0

[hosts]
# SSH credentials for test hosts connected to breakout ports.
# Used by stage_22_host_traffic (PENDING).
ssh_user = flax
key_file = ~/.ssh/id_rsa
