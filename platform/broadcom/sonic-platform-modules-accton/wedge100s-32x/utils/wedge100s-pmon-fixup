#!/bin/sh
# wedge100s-pmon-fixup — post-pmon-start container fixups
#
# Runs once after pmon.service starts (via wedge100s-pmon-fixup.service).
# Handles operations that require a running pmon container and cannot be
# done in the postinst (which runs during dpkg -i, before Docker/pmon).
#
# Triggered by the postinst leaving /run/wedge100s/pmon-fixup-needed.
# The systemd unit's ExecStartPost removes the marker after success.

set -e

PLATFORM_WHEEL="/usr/share/sonic/platform/sonic_platform-1.0-py3-none-any.whl"

log() { echo "wedge100s-pmon-fixup: $*"; }

# Wait for pmon container to be fully running (supervisord responding)
wait_pmon() {
    local i=0
    while [ $i -lt 30 ]; do
        if docker exec pmon supervisorctl status >/dev/null 2>&1; then
            return 0
        fi
        sleep 2
        i=$((i + 1))
    done
    log "WARNING: pmon supervisord not responding after 60s"
    return 1
}

wait_pmon || exit 0

# 1. Force-reinstall sonic_platform wheel inside pmon container.
#    The wheel is bind-mounted from the host but docker_init.sh skips reinstall
#    if sonic_platform is already importable. Force-reinstall so container picks
#    up chassis.py/sfp.py changes immediately.
if docker exec pmon test -f "$PLATFORM_WHEEL" 2>/dev/null; then
    docker exec pmon pip3 install --quiet --force-reinstall "$PLATFORM_WHEEL" 2>/dev/null || true
    log "reinstalled sonic_platform wheel in pmon container"
fi

# 2. Ensure openssh-client (ssh binary) is available inside pmon.
#    bmc.py uses subprocess.run(['ssh', ...]) for BMC communication.
#    The pmon Docker image does not include openssh-client; copy the host
#    binary and its shared libraries until the Dockerfile is rebuilt.
if ! docker exec pmon which ssh >/dev/null 2>&1; then
    SSH_BIN=$(which ssh 2>/dev/null)
    if [ -n "$SSH_BIN" ]; then
        docker cp "$SSH_BIN" pmon:/usr/bin/ssh 2>/dev/null || true
        for lib in $(ldd "$SSH_BIN" 2>/dev/null | awk '/=>/{print $3}' | grep -v '^('); do
            [ -f "$lib" ] && docker exec pmon test -f "$lib" 2>/dev/null || \
                docker cp "$lib" pmon:"$lib" 2>/dev/null || true
        done
        log "copied ssh binary into pmon container"
    fi
fi

# 3. Patch psud poll interval: 3s → 30s (PSU insertion is a human-scale event).
#    Reduces I2C traffic through the CP2112 USB bridge.
if docker exec pmon grep -q 'PSU_INFO_UPDATE_PERIOD_SECS = 3' /usr/local/bin/psud 2>/dev/null; then
    docker exec pmon sed -i 's/PSU_INFO_UPDATE_PERIOD_SECS = 3/PSU_INFO_UPDATE_PERIOD_SECS = 30/' \
        /usr/local/bin/psud 2>/dev/null || true
    log "patched psud poll interval 3s → 30s"
fi

# 4. Restart xcvrd and psud to pick up updated wheel and psud patch.
docker exec pmon supervisorctl restart xcvrd psud 2>/dev/null || true
log "restarted xcvrd and psud"

log "done"
